# Hybrid — Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# Host header is preserved (Caddy default), which the app's host->tenant
# middleware depends on. Records for *.hybrid.ecomex.cloud are DNS-only
# (grey-cloud) in Cloudflare so Caddy terminates TLS directly per-host.

# Global on-demand TLS gate. For any tenant storefront subdomain Caddy doesn't
# already have a cert for, it asks the app whether the host is a real tenant
# BEFORE touching Let's Encrypt — this prevents an attacker pointing arbitrary
# *.hybrid.ecomex.cloud names at the box to exhaust LE rate limits.
{
	on_demand_tls {
		ask http://web:3000/api/internal/tls-allow
	}
}

# Baseline security headers (transport, clickjacking, MIME sniffing, referrer).
# Full CSP deferred (app ships inline styles; nonce-based CSP is a follow-up).
(app_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

# Apex marketing (Cloudflare-proxied) — managed cert, no on-demand. Kept as its
# OWN block so it does NOT overlap the *.hybrid on-demand policy below.
hybrid.ecomex.cloud {
	encode zstd gzip
	import app_headers
	reverse_proxy web:3000
}

# Everything under *.hybrid.ecomex.cloud served by the app — admin, super-admin,
# AND every tenant storefront — uses ONE on-demand TLS policy (no explicit blocks
# that would overlap and cause a TLS automation conflict). Caddy obtains a per-
# hostname LE cert at the handshake, gated by the ask endpoint (active tenants +
# the fixed platform hosts are allowlisted; everything else is refused). A newly-
# provisioned seller's subdomain serves HTTPS with no Caddyfile change. cdn.* has
# its own more-specific block below for routing (to MinIO); its cert still comes
# through this on-demand policy (cdn is allowlisted in the ask gate).
*.hybrid.ecomex.cloud {
	encode zstd gzip
	tls {
		on_demand
	}
	import app_headers
	reverse_proxy web:3000
}

# Hybrid Pay (self-hosted PipraPay engine) — its own PHP container. More-specific
# than the *.hybrid wildcard so this block wins routing; uses on_demand TLS to
# match the wildcard policy (no managed-vs-on-demand conflict). pay.* is
# allowlisted in the ask gate (PLATFORM_HOSTS). Started by docker-compose.hybridpay.yml.
pay.hybrid.ecomex.cloud {
	encode zstd gzip
	tls {
		on_demand
	}
	import app_headers
	reverse_proxy hybrid-piprapay:80
}

# Public CDN for product/media objects only. The MinIO S3 API exposes bucket
# listing, PUT/DELETE, and admin endpoints on the same port — so we DON'T forward
# everything. Only GET/HEAD reads under the public media bucket path reach MinIO;
# anything else (other buckets, writes, S3 admin, listing) gets a flat 403.
cdn.hybrid.ecomex.cloud {
	encode zstd gzip

	# on_demand so this block's TLS policy matches the *.hybrid wildcard policy
	# (no managed-vs-on-demand conflict); cdn is allowlisted in the ask gate.
	tls {
		on_demand
	}

	@ok {
		method GET HEAD
		path /hybrid-media/*
	}
	reverse_proxy @ok supabase-minio:9000

	respond 403
}

# n8n automation — Cloudflare-proxied host (CF passes ACME HTTP-01 to origin,
# same as the hybrid apex). Managed LE cert; proxies to the n8n container on
# the shared hybrid_default network. WS upgrade is automatic.
n8n.ecomex.cloud {
    encode zstd gzip
    import app_headers
    reverse_proxy n8n:5678
}
