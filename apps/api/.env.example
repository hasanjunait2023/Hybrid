# Hybrid jobs service — env. Copy to .env for local dev.
# Mirrors the web app's contract. DATABASE_URL MUST be app_runtime_login (non-
# superuser) so RLS is FORCED. APP_ENCRYPTION_KEY must match the web app's key
# (it opens the same sealed courier/payment credentials). CRON_SECRET must match
# whatever scheduler triggers /jobs/*.

DATABASE_URL=postgres://app_runtime_login:app_runtime_local_pw@localhost:5432/postgres
DIRECT_URL=postgres://postgres:postgres@localhost:5432/postgres
APP_ENCRYPTION_KEY=/e9mXQaa3JuDz/82MaoeynOpPzHv6qm7bo2jtM8sCaw=
CRON_SECRET=dev-cron-secret

STEADFAST_BASE_URL=https://portal.steadfast.com.bd/api/v1
HTTP_TIMEOUT_SECONDS=15
DB_POOL_MIN=1
DB_POOL_MAX=10
LOG_LEVEL=INFO
ENVIRONMENT=development
