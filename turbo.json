{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "REDIS_URL",
    "NEXT_PUBLIC_ROOT_DOMAIN",
    "NODE_ENV",
    "APP_ENCRYPTION_KEY",
    "AUTH_PROVIDER",
    "DEV_SESSION_SECRET",
    "SESSION_SECRET",
    "SESSION_MAX_AGE_SECONDS",
    "CRON_SECRET",
    "SMS_LIVE",
    "SMS_API_KEY",
    "SMS_SENDER_ID",
    "BLOB_DRIVER",
    "S3_BUCKET",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_PUBLIC_URL",
    "PLATFORM_S3_BUCKET",
    "PLATFORM_S3_ENDPOINT",
    "PLATFORM_S3_REGION",
    "PLATFORM_S3_ACCESS_KEY_ID",
    "PLATFORM_S3_SECRET_ACCESS_KEY",
    "VERCEL_DOMAINS_ENABLED",
    "VERCEL_API_TOKEN",
    "VERCEL_PROJECT_ID",
    "VERCEL_TEAM_ID",
    "VERCEL_CNAME_TARGET",
    "WHATSAPP_ENABLED",
    "GA4_ENABLED",
    "CAPI_ENABLED"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:gen": {
      "cache": false,
      "outputs": ["src/types.ts"]
    }
  }
}
