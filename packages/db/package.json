{
  "name": "@hybrid/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/migrate.ts --seed",
    "db:gen": "tsx scripts/generate-types.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@hybrid/config": "workspace:*",
    "@types/node": "^22.10.7",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "kysely": "^0.27.5",
    "kysely-codegen": "^0.18.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
