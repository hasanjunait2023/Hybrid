# ---------------------------------------------------------------------------
# Hybrid — environment template. Copy to .env.local for local development.
# Local-first: defaults below target the docker-compose Postgres + Redis.
# Cloud values are STUBBED — fill in for staging/production only.
# ---------------------------------------------------------------------------

# Database — runtime connection (RLS engaged; non-superuser app_runtime_login)
DATABASE_URL=postgres://app_runtime_login:app_runtime_local_pw@localhost:5432/hybrid
# Database — direct/superuser connection (migrations, seed, host lookup, type gen)
DIRECT_URL=postgres://postgres:postgres@localhost:5432/hybrid

# Redis (Upstash-compatible; local redis:7-alpine)
REDIS_URL=redis://localhost:6379

# Tenant routing root domain (lvh.me resolves *.lvh.me -> 127.0.0.1 in all browsers)
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me

# App-layer encryption key for gateway/courier credentials (base64-encoded 32 bytes).
# Generate a fresh one for staging/prod: openssl rand -base64 32
APP_ENCRYPTION_KEY=/e9mXQaa3JuDz/82MaoeynOpPzHv6qm7bo2jtM8sCaw=

# --- Auth (Phase 2: own auth — Supabase dropped) ---------------------------

# Auth provider: "dev" (HMAC dev-login cookie; local only, production-gated)
# or "password" (Phase 2 production default — own auth, opaque DB session tokens).
AUTH_PROVIDER=dev

# Dev auth stub — signs the hybrid_dev_session cookie (dev only).
DEV_SESSION_SECRET=dev-only-change-me

# Own-auth session signing secret (AUTH_PROVIDER=password). 32+ random bytes.
# Generate: openssl rand -base64 32 — fail-fast if unset in production.
SESSION_SECRET=dev-only-session-secret-change-me
# Session lifetime in seconds (default 7 days).
SESSION_MAX_AGE_SECONDS=604800

# --- Platform SMS (signup OTP) ---------------------------------------------
# Platform-level sms.net.bd key used ONLY for signup OTP delivery.
# Per-tenant SMS keys (customer notifications) are pasted in Settings and stored
# SEALED in the DB — never here. Leave SMS_LIVE unset (or =0) for log-mode.
SMS_LIVE=
SMS_API_KEY=
SMS_SENDER_ID=

# Cron secret — required by /api/internal/billing-sweep and /api/internal/courier-sync.
# Set in Vercel Cron config (production) or pass manually for local testing.
CRON_SECRET=

# --- Blob storage ----------------------------------------------------------
# Driver: "local" (default, writes to public/uploads/) or "s3" (production).
BLOB_DRIVER=local

# S3-compatible storage (BLOB_DRIVER=s3 only — R2 / B2 / S3 / MinIO).
# Leave empty for local dev. S3_ENDPOINT empty = AWS S3; full URL for R2/B2/MinIO.
# S3_BUCKET=hybrid-product-images
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=
# Platform bucket (theme previews, platform assets) — separate bucket.
# PLATFORM_S3_BUCKET=hybrid-platform-assets
# PLATFORM_S3_ENDPOINT=
# PLATFORM_S3_REGION=auto
# PLATFORM_S3_ACCESS_KEY_ID=
# PLATFORM_S3_SECRET_ACCESS_KEY=

# --- Custom domains (Phase 2; flag-gated) ----------------------------------
# Off by default: domain rows + DNS instructions are written WITHOUT calling Vercel.
VERCEL_DOMAINS_ENABLED=false
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
# CNAME target for www records (Vercel project-specific; never hardcoded). When
# unset, the Settings DNS card falls back to the documented cname.vercel-dns.com.
VERCEL_CNAME_TARGET=

# NOTE: Per-tenant provider credentials (bKash, Nagad, SSLCommerz, Steadfast,
# Pathao, tenant SMS, WhatsApp) are NOT env vars. Each tenant pastes its own
# credentials in Settings; they are sealed with APP_ENCRYPTION_KEY and stored in
# the DB (payment_account / courier_account). The ONLY platform-level provider
# key in env is the signup-OTP SMS key above.
