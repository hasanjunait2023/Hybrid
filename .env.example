# ---------------------------------------------------------------------------
# Hybrid — environment template. Copy to .env.local for local development.
# Local-first: defaults below target the docker-compose Postgres + Redis.
# Cloud values are STUBBED — fill in for staging/production only.
# ---------------------------------------------------------------------------

# Database — runtime connection (RLS engaged; non-superuser app_runtime_login)
DATABASE_URL=postgres://app_runtime_login:app_runtime_local_pw@localhost:5432/hybrid
# Database — direct/superuser connection (migrations, seed, host lookup, type gen)
DIRECT_URL=postgres://postgres:postgres@localhost:5432/hybrid

# Redis (Upstash-compatible; local redis:7-alpine)
REDIS_URL=redis://localhost:6379

# Tenant routing root domain (lvh.me resolves *.lvh.me -> 127.0.0.1 in all browsers)
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me

# App-layer encryption key for gateway/courier credentials (base64-encoded 32 bytes).
# generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# --- Auth ------------------------------------------------------------------

# Auth provider:
#   "dev"      — HMAC dev-login cookie; local only, production-gated.
#   "password" — own auth (Argon2id + opaque DB session tokens). Fallback.
#   "supabase" — Supabase GoTrue is the credential authority (PRODUCTION default
#                on the self-hosted VPS). Login verifies against GoTrue, then the
#                app mints its own opaque session. Users live in auth.users.
AUTH_PROVIDER=dev

# Dev auth stub — signs the hybrid_dev_session cookie (dev only).
DEV_SESSION_SECRET=dev-only-change-me

# Session signing secret (AUTH_PROVIDER=password|supabase — both mint the opaque
# hybrid_session). 32+ random bytes. Generate: openssl rand -base64 32 — fail-fast
# if unset in production.
SESSION_SECRET=dev-only-session-secret-change-me
# Session lifetime in seconds (default 7 days).
SESSION_MAX_AGE_SECONDS=604800

# Supabase GoTrue (AUTH_PROVIDER=supabase). SUPABASE_URL is the internal Kong
# gateway on the Docker network in production. Keys are the project anon /
# service_role JWTs (from the self-hosted Supabase .env: SERVICE_SUPABASEANON_KEY
# and SERVICE_SUPABASESERVICE_KEY). Leave blank for local dev/password mode.
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Platform SMS (signup OTP) ---------------------------------------------
# Platform-level sms.net.bd key used ONLY for signup OTP delivery.
# Per-tenant SMS keys (customer notifications) are pasted in Settings and stored
# SEALED in the DB — never here. Leave SMS_LIVE unset (or =0) for log-mode.
SMS_LIVE=
SMS_API_KEY=
SMS_SENDER_ID=

# Cron secret — required by /api/internal/billing-sweep and /api/internal/courier-sync.
# Set in Vercel Cron config (production) or pass manually for local testing.
CRON_SECRET=

# --- Blob storage ----------------------------------------------------------
# Driver: "local" (default, writes to public/uploads/) or "s3" (production).
# PRODUCTION uses "s3" against the self-hosted Supabase MinIO (see values below).
BLOB_DRIVER=local

# S3-compatible storage (BLOB_DRIVER=s3 only — MinIO / R2 / B2 / S3).
# S3_ENDPOINT empty = AWS S3; full URL for MinIO/R2/B2. MinIO needs path-style.
# S3_PUBLIC_BASE_URL is the public host product_image.url points at (must be
# reachable by customer browsers); object URLs are {S3_PUBLIC_BASE_URL}/{key}.
#
# Production (self-hosted Supabase MinIO):
#   S3_BUCKET=hybrid-media
#   S3_ENDPOINT=http://supabase-minio:9000
#   S3_REGION=us-east-1
#   S3_FORCE_PATH_STYLE=true
#   S3_ACCESS_KEY_ID=<MinIO root user>
#   S3_SECRET_ACCESS_KEY=<MinIO root password>
#   S3_PUBLIC_BASE_URL=https://cdn.hybrid.ecomex.cloud/hybrid-media
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
# Platform bucket (theme previews, platform assets) — separate bucket.
# PLATFORM_S3_BUCKET=hybrid-platform-assets
# PLATFORM_S3_ENDPOINT=
# PLATFORM_S3_REGION=auto
# PLATFORM_S3_ACCESS_KEY_ID=
# PLATFORM_S3_SECRET_ACCESS_KEY=

# --- WhatsApp notifications (Phase 2; flag-gated) --------------------------
# Off by default: the post-order WhatsApp confirmation runs LOG-ONLY until set
# to 1, so dev/test never depends on a WABA, an approved Meta template, or
# per-message billing. Per-tenant WhatsApp Cloud API credentials (wabaId,
# phoneNumberId, accessToken) are NOT env vars — each tenant pastes its own in
# Settings; they are sealed with APP_ENCRYPTION_KEY and stored in the DB.
WHATSAPP_ENABLED=

# --- Custom domains (Phase 2) -----------------------------------------------
# Self-hosted Caddy on-demand TLS: no external API needed. Verification is
# DNS-based (TXT ownership proof + A record routing check). Set VPS IP here;
# defaults to the production VPS if unset (safe for local dev — DNS checks will
# simply return false, keeping domains in pending_dns until pointed at the VPS).
CUSTOM_DOMAIN_VPS_IP=72.62.228.196

# --- Analytics (Phase 2.7; flag-gated) -------------------------------------
# Server-side GA4 Measurement Protocol + Meta Conversions API fires. OFF by
# default (dev/test): the deduped purchase event is still generated and the
# client Pixel/gtag still load, but no server-side HTTP call is made until these
# are =true. Per-tenant GA4/Pixel IDs + secrets are NOT env vars — each tenant
# pastes its own in Settings (public IDs plaintext; ga4ApiSecret + fbAccessToken
# sealed with APP_ENCRYPTION_KEY).
GA4_ENABLED=false
CAPI_ENABLED=false

# NOTE: Per-tenant provider credentials (bKash, Nagad, SSLCommerz, Steadfast,
# Pathao, tenant SMS, WhatsApp) are NOT env vars. Each tenant pastes its own
# credentials in Settings; they are sealed with APP_ENCRYPTION_KEY and stored in
# the DB (payment_account / courier_account). The ONLY platform-level provider
# key in env is the signup-OTP SMS key above.

# --- Hybrid Pay (self-hosted PipraPay engine) ------------------------------
# Hybrid Pay is the single white-labeled online gateway. The shared instance
# base URL is platform-level (one self-hosted PipraPay for all tenants); each
# tenant pastes only THEIR per-brand API key in Settings (sealed in the DB).
# HYBRIDPAY_BASE_URL is the default stamped into a tenant's sealed creds when
# they don't override it. See docs/INFRA_HYBRIDPAY.md.
HYBRIDPAY_BASE_URL=https://pay.hybrid.ecomex.cloud
# MySQL for the PipraPay container (docker-compose --profile hybridpay). Only
# needed on the host that runs the engine.
PIPRAPAY_DB_NAME=piprapay
PIPRAPAY_DB_USER=piprapay
PIPRAPAY_DB_PASSWORD=change_me
PIPRAPAY_DB_ROOT_PASSWORD=change_me
